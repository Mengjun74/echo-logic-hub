# ═══════════════════════════════════════════════════════════════
# Echo-Logic Hub — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# Google Gemini API Key (required for LLM features)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face token for pyannote model downloads
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Path to local STT model checkpoint (optional)
# If not set, the model will be downloaded from NGC on first run
LOCAL_STT_MODEL_PATH=

# ─── Mock Mode Flags ─────────────────────────────────────────
# Set these to 'true' to run without hardware/API dependencies.
# Perfect for UI development and testing.

# Use simulated audio instead of a real microphone
USE_MOCK_AUDIO=true

# Use a fake STT engine (no GPU or model download needed)
USE_MOCK_NEMO=true

# Use a fake Gemini client (no API key needed)
USE_MOCK_GEMINI=true
